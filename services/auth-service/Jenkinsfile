pipeline {
    agent any

    environment {
        SERVICE_NAME = 'auth-service'
        ECR_REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
        IMAGE_NAME    = "${ECR_REGISTRY}/vrdcapital/${SERVICE_NAME}"
        IMAGE_TAG     = "${env.GIT_COMMIT[0..7]}"
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Checkout') {
            steps { checkout scm }
        }

        stage('Lint & Test') {
            steps {
                dir("services/${SERVICE_NAME}") {
                    sh '''
                        pip install -r requirements.txt
                        python -m pytest tests/ -v --junitxml=test-results.xml || true
                        python -m flake8 app/ --max-line-length=120 || true
                    '''
                }
            }
            post {
                always {
                    junit "services/${SERVICE_NAME}/test-results.xml"
                }
            }
        }

        stage('Build Image') {
            steps {
                dir("services/${SERVICE_NAME}") {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Security Scan') {
            steps {
                sh "trivy image --exit-code 0 --severity HIGH,CRITICAL ${IMAGE_NAME}:${IMAGE_TAG}"
            }
        }

        stage('Push to ECR') {
            when { branch 'main' }
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-ecr-credentials']]) {
                    sh """
                        aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Update GitOps') {
            when { branch 'main' }
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-credentials', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh """
                        git clone https://${GIT_USER}:${GIT_TOKEN}@github.com/your-org/vrdcapital-gitops.git gitops
                        cd gitops
                        sed -i "s|image: ${IMAGE_NAME}:.*|image: ${IMAGE_NAME}:${IMAGE_TAG}|g" apps/${SERVICE_NAME}/deployment.yaml
                        git config user.email "jenkins@vrdcapital.com"
                        git config user.name "Jenkins CI"
                        git add -A
                        git commit -m "ci: update ${SERVICE_NAME} to ${IMAGE_TAG}" || true
                        git push
                    """
                }
            }
        }
    }

    post {
        failure {
            slackSend(channel: '#devops-alerts', color: 'danger', message: "FAILED: ${SERVICE_NAME} build ${env.BUILD_NUMBER}")
        }
        success {
            slackSend(channel: '#deployments', color: 'good', message: "DEPLOYED: ${SERVICE_NAME}:${IMAGE_TAG}")
        }
        always {
            sh 'docker image prune -f || true'
        }
    }
}
