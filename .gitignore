# Environment — never commit real credentials
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / frontend
node_modules/
frontend/dist/
frontend/.env
*.tsbuildinfo

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Secrets / keys
*.pem
*.key
*.p12
*.pfx

# Terraform — never commit state or real variable values
terraform/.terraform/
terraform/**/.terraform/
terraform/environments/prod/terraform.tfvars
terraform/environments/staging/terraform.tfvars
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
terraform/.terraform.lock.hcl
terraform/**/.terraform.lock.hcl
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# AWS credentials / kubeconfig
.aws/credentials
kubeconfig
*.kubeconfig

# Logs
*.log
logs/
