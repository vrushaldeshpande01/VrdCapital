# ============================================================
# VrdCapital - Portfolio Management Platform
# Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# Database
POSTGRES_USER=vrdcapital
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=vrdcapital
DATABASE_URL=postgresql+asyncpg://vrdcapital:CHANGE_ME_strong_db_password@localhost:5432/vrdcapital

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_min_16_chars
REDIS_URL=redis://:CHANGE_ME_redis_password_min_16_chars@localhost:6379/0

# RabbitMQ
RABBITMQ_USER=vrdcapital
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password
RABBITMQ_URL=amqp://vrdcapital:CHANGE_ME_rabbitmq_password@localhost:5672/

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_minimum_64_character_random_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Services
AUTH_SERVICE_URL=http://localhost:8001
CLIENT_SERVICE_URL=http://localhost:8002

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# Zerodha Kite Connect — create app at https://kite.trade
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here

# Alpha Vantage — get free key at https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=http://localhost/api
VITE_APP_NAME=VrdCapital
