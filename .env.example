# ============================================================
# VrdCapital - Portfolio Management Platform
# Environment Variables
# ============================================================

# Database
POSTGRES_USER=vrdcapital
POSTGRES_PASSWORD=vrdcapital123
POSTGRES_DB=vrdcapital
DATABASE_URL=postgresql+asyncpg://vrdcapital:vrdcapital123@localhost:5432/vrdcapital

# Redis
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@localhost:6379/0

# RabbitMQ
RABBITMQ_USER=vrdcapital
RABBITMQ_PASSWORD=rabbitmq123
RABBITMQ_URL=amqp://vrdcapital:rabbitmq123@localhost:5672/

# Security
SECRET_KEY=supersecretkey-change-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Services
AUTH_SERVICE_URL=http://localhost:8001
CLIENT_SERVICE_URL=http://localhost:8002

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=http://localhost/api
VITE_APP_NAME=VrdCapital
